---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';

const pieces = (await getCollection('artwork')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---
<Base title="camwham — art by Cameron">
  <ul class="gallery">
    {pieces.map((piece) => (
      <li>
        <a href={`/art/${piece.id}/`}>
          <Image
            src={piece.data.image}
            alt={piece.data.title}
            widths={[320, 640]}
            sizes="(min-width: 768px) 33vw, 100vw"
          />
          <div class="caption">
            <h2>{piece.data.title}</h2>
            <time datetime={piece.data.date.toISOString()}>
              {piece.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
        </a>
      </li>
    ))}
  </ul>
</Base>
